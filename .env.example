# Required: OAuth application credentials from apps.developer.allegro.pl
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# Required: User-Agent header, as mandated by Allegro REST API terms (art. 3.4(c)).
# Format: application-name/version (contact-email)
ALLEGRO_USER_AGENT=allegro-mcp/0.2 (you@example.com)

# Optional: environment selection
# Values: production | sandbox
ALLEGRO_ENVIRONMENT=production

# Optional: paths to persistent state
# Defaults below resolve to ~/.allegro-mcp/...
# ALLEGRO_TOKEN_DB_PATH=~/.allegro-mcp/tokens.db
# ALLEGRO_HISTORY_DB_PATH=~/.allegro-mcp/history.db

# Optional: MCP server transport
ALLEGRO_MCP_PORT=8765
ALLEGRO_MCP_BIND=127.0.0.1

# Optional: bearer token required on every MCP request.
# If unset, the transport accepts any caller — only safe on a loopback bind.
# Generate something long and random and inject via your secret manager.
# ALLEGRO_MCP_BEARER=

# Optional: comma-separated list of tool modules to load.
# Default is all buy-side modules.
# ALLEGRO_MCP_MODULES=search,deep_search,offer,product,category,seller,purchases,messaging,bidding,ratings,disputes,compare,intel,purchase_handoff

# Optional: postal code used for landed-cost calculations.
# ALLEGRO_DEFAULT_POSTAL_CODE=00-001

# Optional: client-side rate limit, requests per second.
ALLEGRO_RATE_LIMIT_RPS=60

# Required if the internal snapshot endpoint is exposed: shared secret for
# /internal/snapshot-offers. Sent by the caller as `X-Internal-Secret`.
# ALLEGRO_INTERNAL_SECRET=
